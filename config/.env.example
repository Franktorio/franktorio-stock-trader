# THIS MODULE IS SECRETED AND SHOULD NOT BE SHARED PUBLICLY; .env FILE CONTAINS SENSITIVE CONFIGURATION SETTINGS
# .env.example is just a template. Copy this file and rename to just .env and fill in with your actual values.
# Dont forget to add .env to your .gitignore file to prevent accidentally committing it to a repository.

# Whether the application is running in development or production mode, only affects debug logging
# DEFAULT = 'development'
OPERATING_MODE = 'development'

# API CONFIGURATION =====================================================

# Whether the API thread will be started alongside the main application
# DEFAULT = 'true'
API_ENABLED = 'true'

# Port for the API to listen on
# DEFAULT = '8000'
API_PORT = '8000'

# Secret key for API authentication, should be a long random string
# DEFAULT = 'supersecretkey_PLEASE_CHANGE_ME'
API_SECRET_KEY = 'supersecretkey_PLEASE_CHANGE_ME'

# DATABASE CONFIGURATION ================================================

# How often the replica database should sync with the main database, in seconds
# DEFAULT = '300' (5 minutes)
DB_REPLICA_SYNC_INTERVAL = '300'

# How often a snapshot of the main database should be taken, in seconds
# DEFAULT = '3600' (1 hour)
DB_SNAPSHOT_INTERVAL = '3600'

# How many snapshots to keep before old ones are deleted
# DEFAULT = '72' (keep last 72 snapshots)
DB_SNAPSHOT_RETENTION_COUNT = '72'

# How often the database performs health checks, in seconds
# DEFAULT = '120' (2 minutes)
DB_HEALTH_CHECK_INTERVAL = '120'

# STARTUP CONFIGURATION ================================================

# Whether to perform every test on startup
# DEFAULT = 'false'
RUN_STARTUP_TESTS = 'false'

# BOT CONFIGURATION ====================================================

# Discord bot token
# DEFAULT = 'your_discord_bot_token_here'
DISCORD_BOT_TOKEN = 'your_discord_bot_token_here'

# Owner ID for the Discord bot, used to restrict certain commands to the bot owner
# DEFAULT = 'your_discord_user_id_here'
DISCORD_OWNER_ID = 'your_discord_user_id_here'

# Home guild ID for the Discord bot, used to restrict certain commands to a specific server
# DEFAULT = 'your_discord_guild_id_here'
DISCORD_HOME_GUILD_ID = 'your_discord_guild_id_here'

# ALPACA CONFIGURATION =================================================

# ALPACA API key
# DEFAULT = 'your_alpaca_api_key_here'
ALPACA_API_KEY = 'your_alpaca_api_key_here'

# ALPACA API secret key
# DEFAULT = 'your_alpaca_api_secret_key_here'
ALPACA_API_SECRET_KEY = 'your_alpaca_api_secret_key_here'